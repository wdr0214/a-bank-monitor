{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/data/:path*", "destination": "/data/:path*" },
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/:path*", "destination": "/web/:path*" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
