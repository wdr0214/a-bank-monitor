{
  "version": 2,
  "builds": [
    { "src": "api/refresh.js", "use": "@vercel/node" },
    { "src": "web/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/data/(.*)",
      "headers": { "Cache-Control": "no-store" },
      "dest": "/data/$1"
    },
    { "src": "/api/refresh", "dest": "/api/refresh.js" },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}
